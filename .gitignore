# Godot 4 .gitignore
# https://github.com/godotengine/godot/blob/master/.gitignore

# Godot-specific ignores
.import/
export.cfg
export_presets.cfg
.godot/
*.tmp

# Imported translations
*.translation

# Mono/C# ignores
.mono/
data_*/
# C# project files are source-controlled.
# *.csproj
# *.sln

# .NET build artifacts
bin/
obj/
*.user
*.DotSettings.user
.vs/

# OS-specific ignores
.DS_Store
Thumbs.db

# Editor temporary files
*.swp
*.swo
*~

# Build artifacts
build/
dist/
*.exe
*.x86_64
*.x86_32
*.app
*.apk
*.ipa

# Build / debug logs
build_*.txt
godot_*.txt
remaining_errors*.txt

# Game assets are large binaries and are distributed separately.
assets/
BladeHexFrontend/src/assets/
sl.txt

# Generated playability check artifacts
evaluation.json
playability_screenshots/
