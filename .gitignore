# Godot 4 .gitignore
# https://github.com/godotengine/godot/blob/master/.gitignore

# Godot-specific ignores
.import/
export.cfg
export_presets.cfg
.godot/
*.tmp

# Imported translations (automatically generated from CSV files)
*.translation

# Mono-specific ignores
.mono/
data_*/
*.csproj
*.sln

# OS-specific ignores
.DS_Store
Thumbs.db

# Editor temporary files
*.swp
*.swo
*~

# Build artifacts
build/
dist/
*.exe
*.x86_64
*.x86_32
*.app
*.apk
*.ipa