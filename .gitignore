# Godot 4 .gitignore
# https://github.com/godotengine/godot/blob/master/.gitignore

# Godot-specific ignores
.import/
export.cfg
export_presets.cfg
.godot/
*.tmp

# Imported translations (automatically generated from CSV files)
*.translation

# Mono/C# ignores
.mono/
data_*/
# 排除 .csproj 和 .sln（现在需要提交，因为使用 C#）
# *.csproj
# *.sln

# .NET build artifacts
bin/
obj/
*.user
*.DotSettings.user
.vs/

# OS-specific ignores
.DS_Store
Thumbs.db

# Editor temporary files
*.swp
*.swo
*~

# Build artifacts
build/
dist/
*.exe
*.x86_64
*.x86_32
*.app
*.apk
*.ipa